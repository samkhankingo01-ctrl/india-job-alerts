# --- Google Custom Search API (FREE - 100 queries/day) ---
# Step 1: Go to https://programmablesearchengine.google.com/
# Step 2: Create a new search engine (name: India Jobs)
# Step 3: In Settings > Basics, copy the "Search engine ID" (this is GOOGLE_CX)
# Step 4: Go to https://console.cloud.google.com/apis/credentials
# Step 5: Create API Key for "Custom Search API"
# Step 6: Paste both values below

GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CX=your_search_engine_id_here

# --- Optional Settings ---
MAX_JOBS_PER_SOURCE=50
DEDUP_DAYS=7
